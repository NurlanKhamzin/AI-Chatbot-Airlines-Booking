# Duffel Flights API — sign up at https://app.duffel.com/join , create a *test* access token (duffel_test_...).
# Docs: https://duffel.com/docs/guides/getting-started-with-flights
DUFFEL_API_KEY=
# Optional override (default is production API; test tokens still hit test inventory)
DUFFEL_API_BASE=https://api.duffel.com

# LLM: set DEEPSEEK_API_KEY and/or OPENAI_API_KEY. LLM_PROVIDER=auto prefers DeepSeek if its key is set.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
LLM_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Optional: Discord bot (starts with uvicorn when set; enable Message Content Intent in Developer Portal)
DISCORD_BOT_TOKEN=
DISCORD_COMMAND_PREFIX=!flight
# Last resort on macOS SSL errors (insecure): DISCORD_INSECURE_SSL=true
